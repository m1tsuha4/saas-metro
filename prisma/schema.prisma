generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String?
  name               String?
  telephone          String?
  picture            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  role               UserRole            @default(USER)
  emailVerifiedAt    DateTime?
  accounts           Account[]
  aiAgents           AiAgent[]
  emailContacts      EmailContact[]
  emailVerifications EmailVerification[]
  payments           Payment[]
  subscriptions      Subscription[]
  tokens             TokenBlacklist[]
  whatsAppContacts   WhatsAppContact[]

  @@map("user")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenHash])
  @@map("emailverification")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model TokenBlacklist {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("tokenblacklist")
}

model WhatsAppSession {
  id        String   @id @default(cuid())
  label     String?
  ownerId   String?
  statePath String?
  meJid     String?
  connected Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  aiAgents  AiAgent?

  @@map("whatsappsession")
}

model WhatsAppContact {
  id        String   @id @default(cuid())
  ownerId   String
  phone     String
  name      String?
  waJid     String?
  status    String   @default("UNKNOWN")
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, phone])
  @@map("whatsappcontact")
}

model WaCampaign {
  id                String            @id @default(cuid())
  sessionId         String
  type              String
  text              String?
  imageUrl          String?
  delayMs           Int               @default(1000)
  jitterMs          Int               @default(500)
  createdAt         DateTime          @default(now())
  isScheduled       Boolean           @default(false)
  name              String?
  recipients        Json?
  scheduleType      String            @default("SEND_NOW")
  scheduledDate     DateTime?
  scheduledTime     String?
  status            String            @default("PENDING")
  timetableRepeater String?
  messages          WhatsAppMessage[]

  @@map("wacampaign")
}

model WhatsAppMessage {
  id           String      @id @default(cuid())
  contactId    String?
  phone        String
  sessionId    String
  campaignId   String?
  direction    String
  text         String?
  mediaUrl     String?
  status       String
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  messageId    String?     @unique
  rawJson      Json?
  type         String?
  campaign     WaCampaign? @relation(fields: [campaignId], references: [id])

  @@map("whatsappmessage")
}

model GmailAccount {
  id           String         @id @default(cuid())
  ownerId      String
  email        String         @unique
  accessToken  String
  refreshToken String
  tokenType    String
  expiryDate   BigInt
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     GmailMessage[]

  @@map("gmailaccount")
}

model EmailContact {
  id        String   @id @default(cuid())
  ownerId   String
  email     String
  name      String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, email])
  @@map("emailcontact")
}

model EmailCampaign {
  id        String         @id @default(cuid())
  ownerId   String
  fromEmail String
  subject   String
  html      String
  delayMs   Int            @default(1000)
  jitterMs  Int            @default(400)
  createdAt DateTime       @default(now())
  messages  EmailMessage[]

  @@map("emailcampaign")
}

model EmailMessage {
  id         String        @id @default(cuid())
  campaignId String
  contactId  String?
  toEmail    String
  subject    String
  status     String
  error      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id])

  @@map("emailmessage")
}

model ClientLogo {
  id        String   @id @default(cuid())
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clientlogo")
}

model Package {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String
  price         Int
  currency      String         @default("IDR")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  billingCycle  String         @default("monthly")
  subscriptions Subscription[]
  packageLists  PackageList[]  @relation("PackageToPackageList")

  @@map("package")
}

model PackageList {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  packages  Package[] @relation("PackageToPackageList")

  @@map("package_list")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  packageId String
  status    String   @default("ACTIVE")
  startDate DateTime @default(now())
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  package   Package  @relation(fields: [packageId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model Payment {
  id            String    @id @default(cuid())
  userId        String
  packageId     String?
  orderId       String    @unique
  amount        Int
  currency      String    @default("IDR")
  status        String    @default("PENDING")
  paymentType   String?
  transactionId String?
  snapToken     String?
  snapUrl       String?
  paidAt        DateTime?
  metadata      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment")
}

model GmailMessage {
  id             String       @id @default(cuid())
  gmailMessageId String       @unique
  threadId       String
  from           String?
  to             String?
  subject        String?
  snippet        String?
  internalDate   DateTime?
  raw            Json
  gmailAccountId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  labels         String[]
  gmailAccount   GmailAccount @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)

  @@index([gmailAccountId, internalDate])
  @@map("gmailmessage")
}

model WhatsAppConversation {
  id              String    @id @default(cuid())
  sessionId       String
  jid             String
  name            String?
  isGroup         Boolean   @default(false)
  lastMessageId   String?
  lastMessageText String?
  lastMessageType String?
  lastMessageAt   DateTime?
  unreadCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([sessionId, jid])
  @@index([sessionId])
  @@index([lastMessageAt])
  @@map("whatsappconversation")
}

model AiAgent {
  id             String                 @id @default(cuid())
  ownerId        String
  sessionId      String                 @unique
  name           String
  isEnabled      Boolean                @default(false)
  mode           AiMode                 @default(BOT)
  model          String                 @default("gpt-4o-mini")
  temperature    Float                  @default(0.7)
  maxTokens      Int                    @default(500)
  systemPrompt   String?
  fallbackReply  String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  language       String                 @default("id")
  owner          User                   @relation(fields: [ownerId], references: [id])
  session        WhatsAppSession        @relation(fields: [sessionId], references: [id])
  memories       AiConversationMemory[]
  embeddings     AiEmbedding[]
  knowledgeFiles AiKnowledgeFile[]
  usageLogs      AiUsageLog[]

  @@map("aiagent")
}

model AiKnowledgeFile {
  id        String            @id @default(cuid())
  agentId   String
  fileName  String
  fileUrl   String
  fileSize  Int?
  status    FileStatus        @default(PROCESSING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  fileType  KnowledgeFileType @default(FAQ)
  agent     AiAgent           @relation(fields: [agentId], references: [id])

  @@map("aiknowledgefile")
}

model AiEmbedding {
  id        String            @id @default(cuid())
  agentId   String
  content   String
  embedding Json
  createdAt DateTime          @default(now())
  fileId    String?
  fileType  KnowledgeFileType @default(FAQ)
  agent     AiAgent           @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([agentId, fileType])
  @@map("aiembedding")
}

model AiConversationMemory {
  id        String   @id @default(cuid())
  agentId   String
  jid       String
  role      String
  content   String
  createdAt DateTime @default(now())
  agent     AiAgent  @relation(fields: [agentId], references: [id])

  @@index([agentId, jid])
  @@map("aiconversationmemory")
}

model AiUsageLog {
  id               String   @id @default(cuid())
  agentId          String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  createdAt        DateTime @default(now())
  agent            AiAgent  @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@map("aiusagelog")
}

model WaSession {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("wasession")
}

enum UserRole {
  USER
  ADMIN
}

enum AiMode {
  BOT
  HUMAN
}

enum FileStatus {
  PROCESSING
  READY
  FAILED
}

enum KnowledgeFileType {
  COMPANY_PROFILE
  PRICELIST
  FAQ
}
